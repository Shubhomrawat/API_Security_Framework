# ─────────────────────────────────────────────────────────────
#  AI API Testing Framework v2 — Environment Config
# ─────────────────────────────────────────────────────────────

# ── LLM Provider ─────────────────────────────────────────────
# Set ONE of: openai | anthropic
# If not set, auto-detected from whichever API key is present.
LLM_PROVIDER=openai

# OpenAI
OPENAI_API_KEY=your_openai_api_key_here

# Anthropic Claude (alternative provider)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-opus-4-5

# ── Auth ──────────────────────────────────────────────────────
# Mode: none | bearer | apikey | oauth2
AUTH_MODE=none

# Bearer / static header
AUTH_HEADER_NAME=Authorization
AUTH_HEADER_VALUE=

# API Key
APIKEY_HEADER_NAME=X-Api-Key

# OAuth2 client-credentials
OAUTH2_TOKEN_URL=
OAUTH2_CLIENT_ID=
OAUTH2_CLIENT_SECRET=
OAUTH2_SCOPE=

# ── Application ───────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=true

# ── Database (history) ────────────────────────────────────────
HISTORY_DB=aitesting.db

# ── Testing defaults ──────────────────────────────────────────
DEFAULT_TIMEOUT=30
MAX_RETRIES=3
CONCURRENCY_LIMIT=5

# ── Security thresholds ───────────────────────────────────────
HIGH_SEVERITY_THRESHOLD=8
MEDIUM_SEVERITY_THRESHOLD=4
